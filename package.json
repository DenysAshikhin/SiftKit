{
  "name": "siftkit",
  "version": "0.1.0",
  "description": "Windows-first shell-output compression toolkit for Codex workflows.",
  "bin": {
    "siftkit": "bin/siftkit.js"
  },
  "scripts": {
    "start": "nodemon .\\bin\\siftkit.js status-server",
    "build": "tsc -p .\\tsconfig.json",
    "test": "npm run build && node --test .\\tests\\runtime.test.js",
    "postinstall": "node scripts/postinstall.js",
    "refresh-global": "powershell -ExecutionPolicy Bypass -File .\\scripts\\refresh-global.ps1",
    "service-install": "powershell -ExecutionPolicy Bypass -File .\\bin\\siftkit.ps1 install-service",
    "service-uninstall": "powershell -ExecutionPolicy Bypass -File .\\bin\\siftkit.ps1 uninstall-service",
    "ts:build-full": "tsc -p .\\tsconfig.json",
    "ts:run-full": "npm run ts:build-full && node .\\dist\\test-full.js"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "nodemon": "^3.1.10",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "files": [
    "bin",
    "SiftKit",
    "eval",
    "siftKitStatus",
    "scripts",
    "dist",
    "README.md",
    "docs"
  ],
  "license": "UNLICENSED"
}
